# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=merchant_crm
DB_USER=yogeshrode
DB_PASSWORD=your_password_here

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_change_this
