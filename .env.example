# Webhook Configuration
WEBHOOK_SECRET=your_webhook_signing_secret
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY_MS=5000

# Rate Limiting
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Server
PORT=3000
NODE_ENV=development
